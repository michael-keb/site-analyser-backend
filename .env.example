# REQUIRED — Firecrawl API Key (get at https://www.firecrawl.dev/app/api-keys)
FIRECRAWL_API_KEY=

# REQUIRED — OpenAI API Key (get at https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# OPTIONAL — Pipedrive API (creates lead on each submission)
PIPEDRIVE_API_KEY=

# OPTIONAL
MAX_PAGES=15
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
